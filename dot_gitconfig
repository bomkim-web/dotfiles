	email = bomkimdev@gmail.com
[init]
	defaultBranch = main
[pull]
	rebase = false
[core]
	excludesfile = ~/.gitignore_global
	editor = code --wait
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true  # use n and N to move between diff sections
    line-numbers = true
    side-by-side = true
    syntax-theme = gruvbox-dark
[merge]
    conflictStyle = zdiff3